# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# Mapbox Configuration
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here
VITE_MAPBOX_PERSONAL_TOKEN=your_mapbox_personal_token_here

# Twilio Configuration
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# OAuth Credentials (if applicable)
VITE_CLIENT_ID=your_oauth_client_id_here
VITE_CLIENT_SECRET=your_oauth_client_secret_here
VITE_OAUTH_TOKEN=your_oauth_token_here

# API Base URLs
VITE_API_BASE_URL=https://your-project.supabase.co/rest/v1
VITE_SOCKET_URL=ws://localhost:3000
